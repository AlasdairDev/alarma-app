<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.SettingsView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#2D1B4E">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">

    <ScrollView HorizontalOptions="Fill" VerticalOptions="Fill">
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Label Text="Settings"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   Padding="24,52,24,20"
                   BackgroundColor="#2D1B4E" />

            <!-- LOCATION -->
            <Label Text="LOCATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,16,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestLocationPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Location Access"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding LocationPermissionLabel}"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- BATTERY OPTIMIZATION -->
            <Label Text="BATTERY OPTIMIZATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestBatteryOptimizationCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Optimize battery usage"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding BatteryOptimizationLabel}"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- NOTIFICATIONS -->
            <Label Text="NOTIFICATIONS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestNotificationPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Push notifications"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding NotificationPermissionLabel}"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- BLUETOOTH -->
            <Label Text="BLUETOOTH"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Label Grid.Column="0"
                           Text="Enable bluetooth connection"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <!-- Mirrors the live device Bluetooth state; IBluetoothMonitor keeps it in sync. -->
                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsBluetoothOn}"
                            ThumbColor="#9B6FBF"
                            OnColor="#7B3FA0"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- ALARM -->
            <Label Text="ALARM"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <!-- Alarm Sound — a compact dropdown of the 5 sound options. SelectedItem two-way
                         binds to AlarmSound (which persists to Preferences); SelectedIndexChanged plays a
                         live preview of the picked sound, matching the old chips' behaviour. -->
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Alarm Sound"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <!-- Button-like wrapper: rounded background + a chevron on the right so it reads
                             as a tappable dropdown. The Picker itself is transparent with its native
                             underline stripped (OnPickerHandlerChanged), and the chevron is input-
                             transparent so a tap anywhere in the pill still opens the dropdown. -->
                        <Border Grid.Column="1"
                                BackgroundColor="#2D1B4E"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12,4"
                                MinimumWidthRequest="140"
                                VerticalOptions="Center">
                            <Grid>
                                <Picker x:Name="AlarmSoundPicker"
                                        HandlerChanged="OnPickerHandlerChanged"
                                        ItemsSource="{Binding AlarmSoundOptions}"
                                        SelectedItem="{Binding AlarmSound, Mode=TwoWay}"
                                        SelectedIndexChanged="OnAlarmSoundChanged"
                                        TextColor="#C8B8E8"
                                        FontSize="14"
                                        BackgroundColor="Transparent"
                                        HorizontalOptions="Fill" />
                                <Label Text="&#x25BC;"
                                       FontSize="10"
                                       TextColor="#9B6FBF"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center"
                                       Margin="0,0,2,0"
                                       InputTransparent="True" />
                            </Grid>
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Vibration Only"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding VibrationOnly}"
                                ThumbColor="#9B6FBF"
                                OnColor="#7B3FA0"
                                VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- BACKUP -->
            <Label Text="BACKUP"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExportBackupTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Export backup"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRestoreBackupTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Restore backup"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Status -->
            <Label Text="{Binding BackupStatusText}"
                   FontSize="12"
                   TextColor="#8A7AAE"
                   HorizontalOptions="Center"
                   Margin="16,12" />

            <!-- LEGAL -->
            <Label Text="LEGAL"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTermsClicked" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Terms &amp; Conditions"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPrivacyClicked" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Privacy Policy"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="32" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

        <!-- Transient "grey pill" toast — a rounded dark capsule near the bottom that pops up with the
             Export/Import result and auto-dismisses after 3 seconds (see SettingsView.xaml.cs). It floats
             over the scrolling content and ignores input so it can't block taps underneath. -->
        <Border x:Name="ToastPill"
                IsVisible="False"
                InputTransparent="True"
                BackgroundColor="#333333"
                StrokeShape="RoundRectangle 25"
                Stroke="Transparent"
                Padding="22,12"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="24,0,24,40">
            <Label x:Name="ToastLabel"
                   Text=""
                   TextColor="White"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
        </Border>

    </Grid>
</ContentPage>
