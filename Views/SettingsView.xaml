<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.SettingsView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#2D1B4E">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">

    <ScrollView HorizontalOptions="Fill" VerticalOptions="Fill">
        <VerticalStackLayout Spacing="0">

            <!-- Header: back chevron + title. Export/Import (and everything else) live on THIS page, and riders
                 were getting stranded here with no obvious way out, so this chevron pops straight back to Home.
                 It's a 48x48 target — at/above the accessibility minimum — so it's an easy one-handed tap. -->
            <Grid ColumnDefinitions="Auto,*"
                  Padding="12,48,24,20"
                  BackgroundColor="#2D1B4E">
                <Button Grid.Column="0"
                        Text="&#8249;"
                        FontSize="36"
                        BackgroundColor="Transparent"
                        TextColor="White"
                        Padding="0"
                        WidthRequest="48"
                        HeightRequest="48"
                        VerticalOptions="Center"
                        SemanticProperties.Description="Back"
                        SemanticProperties.Hint="Double tap to return to the home screen"
                        Clicked="OnBackClicked" />
                <Label Grid.Column="1"
                       Text="Settings"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       VerticalOptions="Center"
                       Margin="4,0,0,0" />
            </Grid>

            <!-- LOCATION -->
            <Label Text="LOCATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,16,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestLocationPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Location Access"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding LocationPermissionLabel}"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- BATTERY OPTIMIZATION -->
            <Label Text="BATTERY OPTIMIZATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestBatteryOptimizationCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Optimize battery usage"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding BatteryOptimizationLabel}"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- NOTIFICATIONS -->
            <Label Text="NOTIFICATIONS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestNotificationPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Push notifications"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="{Binding NotificationPermissionLabel}"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- BLUETOOTH -->
            <Label Text="BLUETOOTH"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Label Grid.Column="0"
                           Text="Enable bluetooth connection"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <!-- Mirrors the live device Bluetooth state; IBluetoothMonitor keeps it in sync. The
                         binding is OneWay so the hardware drives the switch, never the other way around —
                         a user flip is intercepted in OnBluetoothToggled, which prompts the OS instead of
                         silently flipping the adapter (that crashes on Android 13+). The Toggled handler is
                         null-guarded for the initial inflation pass (see SettingsView.xaml.cs). -->
                    <Switch Grid.Column="1"
                            x:Name="BluetoothSwitch"
                            IsToggled="{Binding IsBluetoothOn, Mode=OneWay}"
                            Toggled="OnBluetoothToggled"
                            ThumbColor="#9B6FBF"
                            OnColor="#7B3FA0"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- ALARM -->
            <Label Text="ALARM"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <!-- Alarm Sound — a compact dropdown of the 5 sound options. SelectedItem two-way
                         binds to AlarmSound (which persists to Preferences); SelectedIndexChanged plays a
                         live preview of the picked sound, matching the old chips' behaviour. -->
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Alarm Sound"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <!-- Button-like wrapper: rounded background + a chevron on the right so it reads
                             as a tappable dropdown. The Picker itself is transparent with its native
                             underline stripped (OnPickerHandlerChanged), and the chevron is input-
                             transparent so a tap anywhere in the pill still opens the dropdown. -->
                        <Border Grid.Column="1"
                                BackgroundColor="#2D1B4E"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12,4"
                                MinimumWidthRequest="140"
                                VerticalOptions="Center">
                            <Grid>
                                <Picker x:Name="AlarmSoundPicker"
                                        HandlerChanged="OnPickerHandlerChanged"
                                        ItemsSource="{Binding AlarmSoundOptions}"
                                        SelectedItem="{Binding AlarmSound, Mode=TwoWay}"
                                        SelectedIndexChanged="OnAlarmSoundChanged"
                                        TextColor="#C8B8E8"
                                        FontSize="14"
                                        BackgroundColor="Transparent"
                                        HorizontalOptions="Fill" />
                                <Label Text="&#x25BC;"
                                       FontSize="10"
                                       TextColor="#9B6FBF"
                                       HorizontalOptions="End"
                                       VerticalOptions="Center"
                                       Margin="0,0,2,0"
                                       InputTransparent="True" />
                            </Grid>
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Vibration Only"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding VibrationOnly}"
                                ThumbColor="#9B6FBF"
                                OnColor="#7B3FA0"
                                VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <!-- Custom alarm sound (Feature 1): tap to import a user-supplied audio file. The
                         sub-label shows the imported file name (or a prompt). A "Remove" row appears only
                         once a custom sound exists, and selecting it falls every choice back to a bundled voice. -->
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnImportCustomSoundTapped" />
                        </Grid.GestureRecognizers>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Custom Alarm Sound"
                                   FontSize="15"
                                   TextColor="White" />
                            <Label Text="{Binding CustomSoundStatusText}"
                                   FontSize="12"
                                   TextColor="#9B6FBF" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="*"
                          Padding="18,0,18,14"
                          IsVisible="{Binding HasCustomSound}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRemoveCustomSoundTapped" />
                        </Grid.GestureRecognizers>
                        <Label Text="Remove custom sound"
                               FontSize="13"
                               TextColor="#E0A0A0"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ALARM SOUND PER STAGE (Feature 2) -->
            <Label Text="ALARM SOUND PER STAGE"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <!-- Each stage picks "Default" (inherit the single Alarm Sound), "None" (vibration-led),
                         any bundled voice, or "Custom". Selecting plays a live preview. Stage 1 (Gentle) is
                         vibration-only by design, so it has no picker — only Stage 2 and Emergency are here. -->
                    <Grid ColumnDefinitions="*,Auto" Padding="18,16">
                        <Label Grid.Column="0" Text="Stage 2 (Escalated)" FontSize="15" TextColor="White" VerticalOptions="Center" />
                        <Border Grid.Column="1" BackgroundColor="#2D1B4E" StrokeShape="RoundRectangle 10" Stroke="Transparent" Padding="12,4" MinimumWidthRequest="140" VerticalOptions="Center">
                            <Grid>
                                <Picker x:Name="Stage2Picker" HandlerChanged="OnPickerHandlerChanged" ItemsSource="{Binding StageSoundOptions}" SelectedItem="{Binding Stage2SoundDisplay, Mode=TwoWay}" SelectedIndexChanged="OnStage2SoundChanged" TextColor="#C8B8E8" FontSize="14" BackgroundColor="Transparent" HorizontalOptions="Fill" />
                                <Label Text="&#x25BC;" FontSize="10" TextColor="#9B6FBF" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,2,0" InputTransparent="True" />
                            </Grid>
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto" Padding="18,16">
                        <Label Grid.Column="0" Text="Emergency (Lockout)" FontSize="15" TextColor="White" VerticalOptions="Center" />
                        <Border Grid.Column="1" BackgroundColor="#2D1B4E" StrokeShape="RoundRectangle 10" Stroke="Transparent" Padding="12,4" MinimumWidthRequest="140" VerticalOptions="Center">
                            <Grid>
                                <Picker x:Name="Stage3Picker" HandlerChanged="OnPickerHandlerChanged" ItemsSource="{Binding StageSoundOptions}" SelectedItem="{Binding Stage3SoundDisplay, Mode=TwoWay}" SelectedIndexChanged="OnStage3SoundChanged" TextColor="#C8B8E8" FontSize="14" BackgroundColor="Transparent" HorizontalOptions="Fill" />
                                <Label Text="&#x25BC;" FontSize="10" TextColor="#9B6FBF" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,2,0" InputTransparent="True" />
                            </Grid>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- OVERSHOOT (Feature 3) -->
            <Label Text="OVERSHOOT"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="8" Padding="18,16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Trigger distance"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="{Binding OvershootDistanceLabel}"
                               FontSize="14"
                               TextColor="#9B6FBF"
                               VerticalOptions="Center" />
                    </Grid>
                    <!-- 50–500 m, default 250. The rider types a value; it's validated and clamped on
                         commit (Enter / focus-loss) by the controller, with empty/garbage reverting to the
                         last valid number. Styled as a rounded pill to match the Settings pickers. -->
                    <Border BackgroundColor="#2D1B4E"
                            StrokeShape="RoundRectangle 10"
                            Stroke="Transparent"
                            Padding="12,2"
                            MinimumWidthRequest="120"
                            HorizontalOptions="Start">
                        <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="4">
                            <Entry x:Name="OvershootEntry"
                                   Grid.Column="0"
                                   HandlerChanged="OnOvershootEntryHandlerChanged"
                                   Text="{Binding OvershootDistanceInput, Mode=TwoWay}"
                                   Keyboard="Numeric"
                                   MaxLength="3"
                                   ReturnType="Done"
                                   Completed="OnOvershootCommitted"
                                   Unfocused="OnOvershootCommitted"
                                   TextColor="#C8B8E8"
                                   FontSize="14"
                                   BackgroundColor="Transparent"
                                   WidthRequest="56" />
                            <Label Grid.Column="1"
                                   Text="m"
                                   FontSize="14"
                                   TextColor="#9B6FBF"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- BACKUP -->
            <Label Text="BACKUP"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExportBackupTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Export backup"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRestoreBackupTapped" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Restore backup"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- LEGAL -->
            <Label Text="LEGAL"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTermsClicked" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Terms &amp; Conditions"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPrivacyClicked" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Privacy Policy"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <BoxView HeightRequest="32" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>

        <!-- Transient "grey pill" toast — a rounded dark capsule near the bottom that pops up with the
             Export/Import result and auto-dismisses after 3 seconds (see SettingsView.xaml.cs). It floats
             over the scrolling content and ignores input so it can't block taps underneath. -->
        <Border x:Name="ToastPill"
                IsVisible="False"
                InputTransparent="True"
                BackgroundColor="#333333"
                StrokeShape="RoundRectangle 25"
                Stroke="Transparent"
                Padding="22,12"
                HorizontalOptions="Center"
                VerticalOptions="End"
                Margin="24,0,24,40">
            <Label x:Name="ToastLabel"
                   Text=""
                   TextColor="White"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />
        </Border>

    </Grid>
</ContentPage>
