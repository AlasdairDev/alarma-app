<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.SettingsView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#2D1B4E">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Header -->
            <Label Text="Settings"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   Padding="24,52,24,20"
                   BackgroundColor="#2D1B4E" />

            <!-- LOCATION -->
            <Label Text="LOCATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,16,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestLocationPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Location Access"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="Allow"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- BATTERY OPTIMIZATION -->
            <Label Text="BATTERY OPTIMIZATION"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestBatteryOptimizationCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Optimize battery usage"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="Allow"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- NOTIFICATIONS -->
            <Label Text="NOTIFICATIONS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestNotificationPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Push notifications"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="Allow"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- BLUETOOTH -->
            <Label Text="BLUETOOTH"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RequestBluetoothPermissionCommand}" />
                    </Grid.GestureRecognizers>
                    <Label Grid.Column="0"
                           Text="Enable bluetooth connection"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="Allow"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- EMERGENCY CONTACTS -->
            <Label Text="EMERGENCY CONTACTS"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <Grid ColumnDefinitions="*,Auto"
                      Padding="18,16">
                    <Label Grid.Column="0"
                           Text="Emergency contacts"
                           FontSize="15"
                           TextColor="White"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Update"
                            FontSize="13"
                            FontAttributes="Bold"
                            BackgroundColor="#7B3FA0"
                            TextColor="White"
                            CornerRadius="16"
                            Padding="18,8"
                            HeightRequest="36"
                            Clicked="OnUpdateContactsClicked" />
                </Grid>
            </Border>

            <!-- ALARM -->
            <Label Text="ALARM"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Alarm Sound"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding AlarmSoundOptions}"
                                SelectedItem="{Binding AlarmSound}"
                                TextColor="#9B6FBF"
                                FontSize="14"
                                BackgroundColor="Transparent"
                                MinimumWidthRequest="100" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Vibration Intensity"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding VibrationIntensityOptions}"
                                SelectedItem="{Binding VibrationIntensity}"
                                TextColor="#9B6FBF"
                                FontSize="14"
                                BackgroundColor="Transparent"
                                MinimumWidthRequest="90" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <Label Grid.Column="0"
                               Text="Vibration Only"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding VibrationOnly}"
                                ThumbColor="#9B6FBF"
                                OnColor="#7B3FA0"
                                VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,16">
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="Alarm Lead Time"
                                   FontSize="15"
                                   TextColor="White" />
                            <Label Text="{Binding AlarmLeadMinutes, StringFormat='{0:F0} min'}"
                                   FontSize="12"
                                   TextColor="#8A7AAE" />
                        </VerticalStackLayout>
                        <Stepper Grid.Column="1"
                                 Minimum="1"
                                 Maximum="60"
                                 Increment="1"
                                 Value="{Binding AlarmLeadMinutes}"
                                 VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- BACKUP -->
            <Label Text="BACKUP"
                   FontSize="11"
                   FontAttributes="Bold"
                   TextColor="#8A7AAE"
                   Margin="24,20,24,6" />
            <Border BackgroundColor="#3D2B5E"
                    StrokeShape="RoundRectangle 12"
                    Stroke="Transparent"
                    Margin="16,0">
                <VerticalStackLayout Spacing="0">
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportBackupCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Export backup"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                    <Grid ColumnDefinitions="*,Auto"
                          Padding="18,14">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RestoreBackupCommand}" />
                        </Grid.GestureRecognizers>
                        <Label Grid.Column="0"
                               Text="Restore backup"
                               FontSize="15"
                               TextColor="White"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1"
                               Text="&#8250;"
                               FontSize="20"
                               TextColor="#8A7AAE"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Status -->
            <Label Text="{Binding BackupStatusText}"
                   FontSize="12"
                   TextColor="#8A7AAE"
                   HorizontalOptions="Center"
                   Margin="16,12" />

            <BoxView HeightRequest="32" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
