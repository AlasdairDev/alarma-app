<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.EmergencyView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">

    <Grid RowDefinitions="Auto,*">

        <!-- SOS section -->
        <VerticalStackLayout Grid.Row="0"
                             HorizontalOptions="Center"
                             Spacing="0"
                             Padding="0,44,0,28">

            <Grid WidthRequest="220"
                  HeightRequest="220"
                  HorizontalOptions="Center">
                <Ellipse WidthRequest="220"
                         HeightRequest="220"
                         Fill="#33FF3B30"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
                <Ellipse WidthRequest="185"
                         HeightRequest="185"
                         Fill="#55FF3B30"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
                <Button x:Name="SosButton"
                        Text="SOS"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="#FF3B30"
                        WidthRequest="150"
                        HeightRequest="150"
                        CornerRadius="75"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        Pressed="OnSosPressed"
                        Released="OnSosReleased" />
            </Grid>

            <Label Text="Press &amp; Hold to Activate"
                   FontSize="16"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   Margin="0,16,0,4" />
            <Label Text="{Binding SosHoldPrompt}"
                   FontSize="13"
                   TextColor="#8A7AAE"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>

        <!-- Emergency contacts management -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,0,16,32" Spacing="0">

                <Label Text="EMERGENCY CONTACTS"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#8A7AAE"
                       Margin="8,0,8,6" />

                <!-- Contacts list -->
                <Border BackgroundColor="#3D2B5E"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent">
                    <VerticalStackLayout Spacing="0">

                        <!-- Empty state -->
                        <Label Text="No contacts added. Use the form below to add up to 3."
                               IsVisible="{Binding HasNoEmergencyContacts}"
                               FontSize="13"
                               TextColor="#8A7AAE"
                               HorizontalOptions="Center"
                               Margin="18,16" />

                        <!-- Contact rows -->
                        <CollectionView ItemsSource="{Binding EmergencyContacts}"
                                        IsVisible="{Binding HasEmergencyContacts}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          Padding="18,14"
                                          ColumnSpacing="12">

                                        <!-- Primary star (tap to promote) -->
                                        <Label Grid.Column="0"
                                               FontSize="20"
                                               VerticalOptions="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsPrimary}"
                                                             Value="True">
                                                    <Setter Property="Text" Value="&#9733;" />
                                                    <Setter Property="TextColor" Value="#FFD700" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding IsPrimary}"
                                                             Value="False">
                                                    <Setter Property="Text" Value="&#9734;" />
                                                    <Setter Property="TextColor" Value="#8A7AAE" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SetPrimaryContactCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>

                                        <!-- Name and number -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding PhoneNumber}"
                                                   FontSize="12"
                                                   TextColor="#8A7AAE" />
                                        </VerticalStackLayout>

                                        <!-- Delete -->
                                        <Label Grid.Column="2"
                                               Text="&#10005;"
                                               FontSize="16"
                                               TextColor="#FF6B6B"
                                               VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveEmergencyContactCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>

                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

                <!-- Add contact form -->
                <Label Text="ADD CONTACT"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#8A7AAE"
                       Margin="8,16,8,6" />
                <Border BackgroundColor="#3D2B5E"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent">
                    <VerticalStackLayout Spacing="0">
                        <Entry Placeholder="Name (max 50 characters)"
                               Text="{Binding NewContactName}"
                               PlaceholderColor="#8A7AAE"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               MaxLength="50"
                               Margin="18,12" />
                        <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                        <Entry Placeholder="09XXXXXXXXX or +639XXXXXXXXX"
                               Text="{Binding NewContactNumber}"
                               PlaceholderColor="#8A7AAE"
                               TextColor="White"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               Keyboard="Telephone"
                               MaxLength="13"
                               Margin="18,12" />
                        <BoxView HeightRequest="1" Color="#4A3570" Margin="18,0" />
                        <Button Text="Add Contact"
                                Command="{Binding AddEmergencyContactCommand}"
                                BackgroundColor="#7B3FA0"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="10"
                                Margin="12,8,12,12" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

    <!-- SOS Sent confirmation overlay (Figma Page 20) -->
    <Grid x:Name="SosSentOverlay"
          IsVisible="False"
          BackgroundColor="#AA000020">
        <Border HorizontalOptions="Center"
                VerticalOptions="Center"
                BackgroundColor="#3D2B5E"
                StrokeShape="RoundRectangle 20"
                Stroke="#6A4590"
                StrokeThickness="1"
                Padding="28,24"
                Margin="32,0">
            <VerticalStackLayout Spacing="14">

                <!-- Dismiss X -->
                <Grid>
                    <Label Text="&#10005;"
                           FontSize="18"
                           TextColor="#8A7AAE"
                           HorizontalOptions="End"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSosSentOverlayDismissed" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Label Text="SOS Sent"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Label Text="Your location has been sent to emergency contacts."
                       FontSize="14"
                       TextColor="#C8B8E8"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />

                <!-- Location chip -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="6">
                    <Label Text="&#128205;"
                           FontSize="14"
                           TextColor="#9B6FBF"
                           VerticalOptions="Center" />
                    <Label x:Name="SosSentLocationLabel"
                           Text=""
                           FontSize="14"
                           TextColor="White"
                           VerticalOptions="Center"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                </HorizontalStackLayout>

                <!-- Call 911 button -->
                <Button Text="Call 911"
                        BackgroundColor="#FF3B30"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        Clicked="OnCall911Clicked" />

            </VerticalStackLayout>
        </Border>
    </Grid>

    </Grid>

</ContentPage>
