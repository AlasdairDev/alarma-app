<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlarmaApp.Views"
             x:Class="AlarmaApp.Views.OnboardingView"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <ContentPage.Resources>

        <!-- Template for slides 0-2: full-screen PNG with invisible Skip/Next tap zones -->
        <DataTemplate x:Key="ImageSlideTemplate">
            <Grid WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="CurrentItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="1.0" />
                                    <Setter Property="Scale" Value="1.0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PreviousItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.9" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="NextItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.9" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="DefaultItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.9" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Image Source="{Binding ImageSource}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />

                <!-- Invisible tap zones aligned over the PNG's baked-in Skip / Next buttons -->
                <Grid VerticalOptions="End"
                      Margin="32,0,32,52"
                      HeightRequest="56"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="16">
                    <Grid Grid.Column="0" BackgroundColor="Transparent">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference ThisPage}, Path=SkipCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                    <Grid Grid.Column="1" BackgroundColor="Transparent">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference ThisPage}, Path=NextCommand}" />
                        </Grid.GestureRecognizers>
                    </Grid>
                </Grid>
            </Grid>
        </DataTemplate>

        <!-- Template for slide 3: illustration (Row 0 *) + Modern Card (Row 1 Auto) -->
        <DataTemplate x:Key="CardSlideTemplate">
            <Grid RowDefinitions="*, Auto"
                  WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="CurrentItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="1.0" />
                                    <Setter Property="Scale" Value="1.0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PreviousItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.9" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="NextItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.9" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="DefaultItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.9" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>

                <!-- Row 0 (*): illustration with gradient scrim at bottom -->
                <Grid Grid.Row="0" BackgroundColor="#1A0F35">
                    <Image Source="{Binding ImageSource}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />

                    <BoxView VerticalOptions="End"
                             HeightRequest="160"
                             HorizontalOptions="Fill">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#1A0F35" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                </Grid>

                <!-- Row 1 (Auto): Modern Card — only T&C, checkbox, Get Started. No Skip/Next. -->
                <Border Grid.Row="1"
                        BackgroundColor="#2D2D44"
                        StrokeThickness="0"
                        HeightRequest="240">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20,20,0,0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14" Padding="20">
                        <Label FontSize="13"
                               TextColor="#C8B8E8"
                               HorizontalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Read our " />
                                    <Span Text="Privacy Policy"
                                          TextColor="#9B6FBF"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                    <Span Text=" and " />
                                    <Span Text="Terms &amp; Conditions"
                                          TextColor="#9B6FBF"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                            <CheckBox Grid.Column="0"
                                      Color="#9B6FBF"
                                      CheckedChanged="OnAgreeCheckChanged"
                                      VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="I have read and agree to the Terms and Conditions and Privacy Policy."
                                   FontSize="13"
                                   TextColor="#C8B8E8"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap" />
                        </Grid>

                        <Button Text="Get Started"
                                FontSize="16"
                                FontAttributes="Bold"
                                BackgroundColor="#7B3FA0"
                                TextColor="White"
                                CornerRadius="28"
                                IsEnabled="{Binding IsAgreed, Source={x:Reference ThisPage}}"
                                Clicked="OnGetStartedClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>

        <local:OnboardingTemplateSelector x:Key="SlideSelector"
                                          ImageTemplate="{StaticResource ImageSlideTemplate}"
                                          CardTemplate="{StaticResource CardSlideTemplate}" />
    </ContentPage.Resources>

    <Grid>
        <CarouselView x:Name="OnboardingCarousel"
                      ItemsSource="{Binding Slides}"
                      ItemTemplate="{StaticResource SlideSelector}"
                      IsSwipeEnabled="False"
                      IsBounceEnabled="False"
                      PeekAreaInsets="0"
                      HorizontalScrollBarVisibility="Never"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   SnapPointsType="MandatorySingle"
                                   SnapPointsAlignment="Center"
                                   ItemSpacing="0" />
            </CarouselView.ItemsLayout>
        </CarouselView>

        <!-- IndicatorView linked to CarouselView; MaximumVisible=4 enforces the 4-dot cap.
             IsVisible="False" because the PNG assets have dots baked in — showing both would double them. -->
        <IndicatorView x:Name="indicatorView"
                       MaximumVisible="4"
                       IsVisible="False" />
    </Grid>
</ContentPage>
