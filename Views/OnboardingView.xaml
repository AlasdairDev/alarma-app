<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlarmaApp.Views"
             x:Class="AlarmaApp.Views.OnboardingView"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <ContentPage.Resources>

        <!-- Slides 1-3: full-screen image with a solid rounded card anchored to the bottom -->
        <DataTemplate x:Key="ImageSlideTemplate">
            <Grid WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">

                <!-- Full-bleed illustration sitting behind the card -->
                <Image Source="{Binding ImageSource}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />

                <!-- Solid dark-purple bottom card -->
                <Border VerticalOptions="End"
                        BackgroundColor="#25174A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 30,30,0,0">
                    <!-- Bottom padding leaves room for the indicator dots below the buttons -->
                    <VerticalStackLayout Spacing="12" Padding="28,28,28,46">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="15"
                               TextColor="#C8B8E8"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="14"
                              Margin="0,12,0,0">
                            <Button Grid.Column="0"
                                    Text="Skip"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="White"
                                    TextColor="#7B3FA0"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=SkipCommand}" />
                            <Button Grid.Column="1"
                                    Text="Next"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=NextCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Slide 4: full-screen image + card with legal links, agreement checkbox and Get Started -->
        <DataTemplate x:Key="CardSlideTemplate">
            <Grid WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">

                <Image Source="{Binding ImageSource}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />

                <Border VerticalOptions="End"
                        BackgroundColor="#25174A"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 30,30,0,0">
                    <VerticalStackLayout Spacing="12" Padding="28,26,28,46">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="15"
                               TextColor="#C8B8E8"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />

                        <Label FontSize="13"
                               Margin="0,4,0,0"
                               HorizontalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Read our " TextColor="#C8B8E8" />
                                    <Span Text="Privacy Policy"
                                          TextColor="#C39BE8"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                    <Span Text=" and " TextColor="#C8B8E8" />
                                    <Span Text="Terms &amp; Conditions"
                                          TextColor="#C39BE8"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                            <CheckBox Grid.Column="0"
                                      x:Name="AgreeCheckBox"
                                      Color="#C39BE8"
                                      CheckedChanged="OnAgreeCheckChanged"
                                      VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="I have read and agree to the Terms and Conditions and Privacy Policy."
                                   FontSize="13"
                                   TextColor="#C8B8E8"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap" />
                        </Grid>

                        <Button Text="Get Started"
                                FontSize="17"
                                FontAttributes="Bold"
                                BackgroundColor="#7B3FA0"
                                TextColor="White"
                                CornerRadius="28"
                                HeightRequest="56"
                                Margin="0,4,0,0"
                                HorizontalOptions="Fill"
                                Clicked="OnGetStartedClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>

        <local:OnboardingTemplateSelector x:Key="SlideSelector"
                                          ImageTemplate="{StaticResource ImageSlideTemplate}"
                                          CardTemplate="{StaticResource CardSlideTemplate}" />
    </ContentPage.Resources>

    <Grid>
        <CarouselView x:Name="OnboardingCarousel"
                      BackgroundColor="Transparent"
                      ItemsSource="{Binding Slides}"
                      ItemTemplate="{StaticResource SlideSelector}"
                      IsSwipeEnabled="False"
                      IsBounceEnabled="False"
                      PeekAreaInsets="0"
                      HorizontalScrollBarVisibility="Never"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      IndicatorView="indicatorView">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   SnapPointsType="MandatorySingle"
                                   SnapPointsAlignment="Center"
                                   ItemSpacing="0" />
            </CarouselView.ItemsLayout>
        </CarouselView>

        <!-- Page-level dots overlaid at the absolute bottom margin of the purple card,
             sitting below the Skip/Next (and Get Started) buttons. -->
        <IndicatorView x:Name="indicatorView"
                       MaximumVisible="4"
                       IndicatorColor="#5A4080"
                       SelectedIndicatorColor="White"
                       IndicatorSize="8"
                       HorizontalOptions="Center"
                       VerticalOptions="End"
                       Margin="0,0,0,16" />
    </Grid>
</ContentPage>
