<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlarmaApp.Views"
             x:Class="AlarmaApp.Views.OnboardingView"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <ContentPage.Resources>

        <!-- Slides 1-3: top illustration, bottom dark-purple card with title/subtitle + Skip/Next -->
        <DataTemplate x:Key="ImageSlideTemplate">
            <Grid RowDefinitions="*, Auto"
                  WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="CurrentItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="1.0" />
                                    <Setter Property="Scale" Value="1.0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PreviousItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="NextItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="DefaultItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>

                <!-- Top section: the illustration, faded into the card with a scrim -->
                <Grid Grid.Row="0">
                    <Image Source="{Binding ImageSource}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />
                    <BoxView VerticalOptions="End"
                             HeightRequest="120"
                             HorizontalOptions="Fill"
                             InputTransparent="True">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#2A1A4D" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                </Grid>

                <!-- Bottom section: dark purple text/control card -->
                <Border Grid.Row="1"
                        BackgroundColor="#2A1A4D"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28,28,0,0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12" Padding="28,26,28,38">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="15"
                               TextColor="#C8B8E8"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="14"
                              Margin="0,12,0,0">
                            <Button Grid.Column="0"
                                    Text="Skip"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="White"
                                    TextColor="#7B3FA0"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=SkipCommand}" />
                            <Button Grid.Column="1"
                                    Text="Next"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=NextCommand}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>

        <!-- Final slide: title/subtitle + legal links, agreement checkbox and Get Started -->
        <DataTemplate x:Key="CardSlideTemplate">
            <Grid RowDefinitions="*, Auto"
                  WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="CurrentItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="1.0" />
                                    <Setter Property="Scale" Value="1.0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="PreviousItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="NextItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="DefaultItem">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="0.4" />
                                    <Setter Property="Scale" Value="0.92" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>

                <Grid Grid.Row="0">
                    <Image Source="{Binding ImageSource}"
                           Aspect="AspectFill"
                           HorizontalOptions="Fill"
                           VerticalOptions="Fill" />
                    <BoxView VerticalOptions="End"
                             HeightRequest="120"
                             HorizontalOptions="Fill"
                             InputTransparent="True">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0" />
                                <GradientStop Color="#2A1A4D" Offset="1" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                </Grid>

                <Border Grid.Row="1"
                        ZIndex="100"
                        BackgroundColor="#2A1A4D"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="28,28,0,0" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="12" Padding="28,24,28,38">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="15"
                               TextColor="#C8B8E8"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />

                        <Label FontSize="13"
                               Margin="0,4,0,0"
                               HorizontalTextAlignment="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Read our " TextColor="#C8B8E8" />
                                    <Span Text="Privacy Policy"
                                          TextColor="#C39BE8"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                    <Span Text=" and " TextColor="#C8B8E8" />
                                    <Span Text="Terms &amp; Conditions"
                                          TextColor="#C39BE8"
                                          TextDecorations="Underline">
                                        <Span.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                        </Span.GestureRecognizers>
                                    </Span>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="8">
                            <CheckBox Grid.Column="0"
                                      Color="#C39BE8"
                                      CheckedChanged="OnAgreeCheckChanged"
                                      VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="I have read and agree to the Terms and Conditions and Privacy Policy."
                                   FontSize="13"
                                   TextColor="#C8B8E8"
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap" />
                        </Grid>

                        <Button Text="Get Started"
                                FontSize="17"
                                FontAttributes="Bold"
                                BackgroundColor="#7B3FA0"
                                TextColor="White"
                                CornerRadius="28"
                                HeightRequest="56"
                                Margin="0,4,0,0"
                                IsEnabled="{Binding IsAgreed, Source={x:Reference ThisPage}}"
                                Clicked="OnGetStartedClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>

        <local:OnboardingTemplateSelector x:Key="SlideSelector"
                                          ImageTemplate="{StaticResource ImageSlideTemplate}"
                                          CardTemplate="{StaticResource CardSlideTemplate}" />
    </ContentPage.Resources>

    <!-- Full-bleed map-grid background sits underneath the carousel/control area -->
    <Grid>
        <Image Source="onboarding_grid.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True" />

        <CarouselView x:Name="OnboardingCarousel"
                      BackgroundColor="Transparent"
                      ItemsSource="{Binding Slides}"
                      ItemTemplate="{StaticResource SlideSelector}"
                      IsSwipeEnabled="False"
                      IsBounceEnabled="False"
                      PeekAreaInsets="0"
                      HorizontalScrollBarVisibility="Never"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      IndicatorView="indicatorView">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   SnapPointsType="MandatorySingle"
                                   SnapPointsAlignment="Center"
                                   ItemSpacing="0" />
            </CarouselView.ItemsLayout>
        </CarouselView>

        <!-- Four-dot progress indicator over the card -->
        <IndicatorView x:Name="indicatorView"
                       MaximumVisible="4"
                       IndicatorColor="#5A4080"
                       SelectedIndicatorColor="White"
                       IndicatorSize="8"
                       HorizontalOptions="Center"
                       VerticalOptions="End"
                       Margin="0,0,0,18" />
    </Grid>
</ContentPage>
