<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlarmaApp.Views"
             x:Class="AlarmaApp.Views.OnboardingView"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <ContentPage.Resources>

        <!-- One template for every slide. The illustration fills the top 55%; the title,
             subtitle and controls float directly over the master grid background below it.
             Skip/Next show on slides 1-3; the legal panel shows only on the last slide. -->
        <DataTemplate x:Key="SlideTemplate">
            <Grid RowDefinitions="5.5*, 4.5*"
                  WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">

                <!-- TOP HALF: seamless illustration -->
                <Image Grid.Row="0"
                       Source="{Binding ImageSource}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />

                <!-- BOTTOM HALF: floating text + controls over the grid background -->
                <Grid Grid.Row="1" Padding="20,0,20,0">

                    <VerticalStackLayout Margin="20,20,20,30"
                                         Spacing="5"
                                         VerticalOptions="Start">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="16"
                               TextColor="#B0A8C0"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />

                        <!-- Skip / Next: hidden on the final slide -->
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="14"
                              Margin="0,16,0,0"
                              IsVisible="{Binding IsNotLastSlide}">
                            <Button Grid.Column="0"
                                    Text="Skip"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="White"
                                    TextColor="#7B3FA0"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=SkipCommand}" />
                            <Button Grid.Column="1"
                                    Text="Next"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=NextCommand}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- SLIDE 4 PANEL: anchored to the absolute bottom, bleeds to the screen edges -->
                    <Border IsVisible="{Binding IsLastSlide}"
                            VerticalOptions="End"
                            BackgroundColor="#1E1533"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 20,20,0,0"
                            Padding="20,20,20,40"
                            Margin="-20,0,-20,-20">
                        <VerticalStackLayout Spacing="16">
                            <HorizontalStackLayout Spacing="10">
                                <CheckBox Color="#C39BE8"
                                          CheckedChanged="OnAgreeCheckChanged"
                                          VerticalOptions="Center" />
                                <Label FontSize="13"
                                       MaximumWidthRequest="260"
                                       TextColor="#C8B8E8"
                                       VerticalOptions="Center"
                                       LineBreakMode="WordWrap">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="I have read and agree to the " />
                                            <Span Text="Terms and Conditions"
                                                  TextColor="#C39BE8"
                                                  TextDecorations="Underline">
                                                <Span.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                                </Span.GestureRecognizers>
                                            </Span>
                                            <Span Text=" and " />
                                            <Span Text="Privacy Policy"
                                                  TextColor="#C39BE8"
                                                  TextDecorations="Underline">
                                                <Span.GestureRecognizers>
                                                    <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                                </Span.GestureRecognizers>
                                            </Span>
                                            <Span Text="." />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <Button Text="Get Started"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="28"
                                    HeightRequest="56"
                                    HorizontalOptions="Fill"
                                    Clicked="OnGetStartedClicked" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <!-- Root layout: the master grid background fills the whole page -->
    <Grid>
        <Image Source="onboarding_grid.png"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               InputTransparent="True" />

        <CarouselView x:Name="OnboardingCarousel"
                      BackgroundColor="Transparent"
                      ItemsSource="{Binding Slides}"
                      ItemTemplate="{StaticResource SlideTemplate}"
                      IsSwipeEnabled="False"
                      IsBounceEnabled="False"
                      PeekAreaInsets="0"
                      HorizontalScrollBarVisibility="Never"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      IndicatorView="indicatorView">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   SnapPointsType="MandatorySingle"
                                   SnapPointsAlignment="Center"
                                   ItemSpacing="0" />
            </CarouselView.ItemsLayout>
        </CarouselView>

        <!-- Dots float near the vertical centre, between the image and the Title -->
        <IndicatorView x:Name="indicatorView"
                       MaximumVisible="4"
                       IndicatorColor="#5A4080"
                       SelectedIndicatorColor="White"
                       IndicatorSize="8"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
    </Grid>
</ContentPage>
