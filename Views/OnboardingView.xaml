<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlarmaApp.Views"
             x:Class="AlarmaApp.Views.OnboardingView"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundImageSource="onboarding_grid.png">

    <ContentPage.Resources>

        <!-- Single template: the illustration bleeds across the top 55%; the title, subtitle
             and controls float directly over the global grid below. Skip/Next hide on the
             final slide via a DataTrigger; the legal panel shows only there. -->
        <DataTemplate x:Key="SlideTemplate">
            <Grid RowDefinitions="55*, 45*"
                  WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">

                <!-- TOP ILLUSTRATION: edge-to-edge, no pillarboxing -->
                <Image Grid.Row="0"
                       Source="{Binding ImageSource}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />

                <!-- BOTTOM FLOATING TEXT -->
                <Grid Grid.Row="1" Padding="20,45,20,20">

                    <VerticalStackLayout VerticalOptions="Start">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="16"
                               TextColor="#A098B0"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               Margin="0,0,0,30" />

                        <!-- Skip / Next: no background card; hidden on the final slide -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid"
                                             Binding="{Binding IsLastSlide}"
                                             Value="True">
                                    <Setter Property="IsVisible" Value="False" />
                                </DataTrigger>
                            </Grid.Triggers>
                            <Button Grid.Column="0"
                                    Text="Skip"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="White"
                                    TextColor="#7B3FA0"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=SkipCommand}" />
                            <Button Grid.Column="1"
                                    Text="Next"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=NextCommand}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- SLIDE 4 TERMS PANEL: flush dark card snapped to bottom/side edges -->
                    <Border IsVisible="{Binding IsLastSlide}"
                            VerticalOptions="End"
                            BackgroundColor="#170F26"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24,24,0,0"
                            Padding="20,20,20,40"
                            Margin="-20,0,-20,-20">
                        <VerticalStackLayout Spacing="14">
                            <Label FontSize="12"
                                   HorizontalTextAlignment="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Read our " TextColor="#A098B0" />
                                        <Span Text="Privacy Policy"
                                              TextColor="#C39BE8"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                            </Span.GestureRecognizers>
                                        </Span>
                                        <Span Text=" and " TextColor="#A098B0" />
                                        <Span Text="Terms &amp; Conditions"
                                              TextColor="#C39BE8"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                            </Span.GestureRecognizers>
                                        </Span>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <HorizontalStackLayout Spacing="10">
                                <CheckBox Color="#C39BE8"
                                          CheckedChanged="OnAgreeCheckChanged"
                                          VerticalOptions="Center" />
                                <Label Text="I have read and agree to the Terms and Conditions and Privacy Policy."
                                       FontSize="14"
                                       MaximumWidthRequest="280"
                                       TextColor="#C8B8E8"
                                       VerticalOptions="Center"
                                       LineBreakMode="WordWrap" />
                            </HorizontalStackLayout>

                            <Button Text="Get Started"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="28"
                                    HeightRequest="56"
                                    HorizontalOptions="Fill"
                                    Clicked="OnGetStartedClicked" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <!-- ROOT: global grid background (page level) + carousel + invisible dots overlay -->
    <Grid>
        <CarouselView x:Name="OnboardingCarousel"
                      BackgroundColor="Transparent"
                      ItemsSource="{Binding Slides}"
                      ItemTemplate="{StaticResource SlideTemplate}"
                      IsSwipeEnabled="False"
                      IsBounceEnabled="False"
                      PeekAreaInsets="0"
                      HorizontalScrollBarVisibility="Never"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      IndicatorView="indicatorView">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   SnapPointsType="MandatorySingle"
                                   SnapPointsAlignment="Center"
                                   ItemSpacing="0" />
            </CarouselView.ItemsLayout>
        </CarouselView>

        <!-- Invisible overlay mirrors the 55*/45* split so the dots lock onto the seam -->
        <Grid InputTransparent="True" RowDefinitions="55*, 45*">
            <IndicatorView x:Name="indicatorView"
                           Grid.Row="1"
                           MaximumVisible="4"
                           IndicatorColor="#5A4080"
                           SelectedIndicatorColor="White"
                           IndicatorSize="8"
                           HorizontalOptions="Center"
                           VerticalOptions="Start"
                           Margin="0,15,0,0" />
        </Grid>
    </Grid>
</ContentPage>
