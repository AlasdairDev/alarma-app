<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AlarmaApp.Views"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="AlarmaApp.Views.OnboardingView"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundImageSource="onboarding_grid.png">

    <ContentPage.Resources>

        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />

        <!-- Single template: the illustration bleeds across the top 55%; the title, subtitle
             and controls float over the master grid background below. Skip/Next show on
             slides 1-3, the legal panel only on the last slide. -->
        <DataTemplate x:Key="SlideTemplate">
            <Grid RowDefinitions="55*, 45*"
                  WidthRequest="{Binding Source={x:Reference OnboardingCarousel}, Path=Width}">

                <!-- TOP ILLUSTRATION: edge-to-edge, no pillarbox borders -->
                <Image Grid.Row="0"
                       Source="{Binding ImageSource}"
                       Aspect="AspectFill"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill" />

                <!-- BOTTOM CONTENT: floats over the grid background -->
                <Grid Grid.Row="1" Padding="24,30,24,30">

                    <VerticalStackLayout VerticalOptions="Start">
                        <Label Text="{Binding Title}"
                               FontSize="26"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Subtitle}"
                               FontSize="16"
                               TextColor="#B0A8C0"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               Margin="0,0,0,30" />

                        <!-- Skip / Next: hidden on the final slide, no background card -->
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="14"
                              IsVisible="{Binding IsLastSlide, Converter={StaticResource InvertedBoolConverter}}">
                            <Button Grid.Column="0"
                                    Text="Skip"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="White"
                                    TextColor="#7B3FA0"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=SkipCommand}" />
                            <Button Grid.Column="1"
                                    Text="Next"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="26"
                                    HeightRequest="52"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=NextCommand}" />
                        </Grid>
                    </VerticalStackLayout>

                    <!-- SLIDE 4 TERMS PANEL: flush dark card snapped to the bottom/side edges -->
                    <Border IsVisible="{Binding IsLastSlide}"
                            VerticalOptions="End"
                            BackgroundColor="#170F26"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24,24,0,0"
                            Padding="24,20,24,40"
                            Margin="-24,0,-24,-30">
                        <VerticalStackLayout Spacing="14">
                            <Label FontSize="12"
                                   HorizontalTextAlignment="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Read our " TextColor="#B0A8C0" />
                                        <Span Text="Privacy Policy"
                                              TextColor="#C39BE8"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                            </Span.GestureRecognizers>
                                        </Span>
                                        <Span Text=" and " TextColor="#B0A8C0" />
                                        <Span Text="Terms &amp; Conditions"
                                              TextColor="#C39BE8"
                                              TextDecorations="Underline">
                                            <Span.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                            </Span.GestureRecognizers>
                                        </Span>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <HorizontalStackLayout Spacing="10">
                                <CheckBox Color="#C39BE8"
                                          CheckedChanged="OnAgreeCheckChanged"
                                          VerticalOptions="Center" />
                                <Label Text="I have read and agree to the Terms and Conditions and Privacy Policy."
                                       FontSize="13"
                                       MaximumWidthRequest="280"
                                       TextColor="#C8B8E8"
                                       VerticalOptions="Center"
                                       LineBreakMode="WordWrap" />
                            </HorizontalStackLayout>

                            <Button Text="Get Started"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    BackgroundColor="#7B3FA0"
                                    TextColor="White"
                                    CornerRadius="28"
                                    HeightRequest="56"
                                    HorizontalOptions="Fill"
                                    Clicked="OnGetStartedClicked" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid>
        <CarouselView x:Name="OnboardingCarousel"
                      BackgroundColor="Transparent"
                      ItemsSource="{Binding Slides}"
                      ItemTemplate="{StaticResource SlideTemplate}"
                      IsSwipeEnabled="False"
                      IsBounceEnabled="False"
                      PeekAreaInsets="0"
                      HorizontalScrollBarVisibility="Never"
                      HorizontalOptions="Fill"
                      VerticalOptions="Fill"
                      IndicatorView="indicatorView">
            <CarouselView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   SnapPointsType="MandatorySingle"
                                   SnapPointsAlignment="Center"
                                   ItemSpacing="0" />
            </CarouselView.ItemsLayout>
        </CarouselView>

        <!-- Dots sit on the horizontal seam between the illustration and the text -->
        <IndicatorView x:Name="indicatorView"
                       MaximumVisible="4"
                       IndicatorColor="#5A4080"
                       SelectedIndicatorColor="White"
                       IndicatorSize="8"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Margin="0,40,0,0" />
    </Grid>
</ContentPage>
