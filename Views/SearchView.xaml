<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:services="clr-namespace:AlarmaApp.Services"
             x:Class="AlarmaApp.Views.SearchView"
             x:Name="SearchPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#2D1B4E">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill" RowDefinitions="Auto,Auto,*">

        <!-- Header: back chevron + centered title. The chevron is a big, easy one-handed touch target —
             a 56x56 button (above the 48dp accessibility minimum) with an oversized glyph — since commuters
             tap it on the move. The side columns are kept equal (56 each) so the title stays truly centred. -->
        <Grid Grid.Row="0"
              ColumnDefinitions="56,*,56"
              Padding="8,48,8,8">
            <Button Grid.Column="0"
                    Text="&#8249;"
                    FontSize="40"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    Padding="0"
                    WidthRequest="56"
                    HeightRequest="56"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"
                    SemanticProperties.Description="Back"
                    SemanticProperties.Hint="Double tap to return to the previous screen"
                    Clicked="OnBackClicked" />
            <Label Grid.Column="1"
                   Text="Where to?"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Node timeline: current location node + connecting line + search input node -->
        <Grid Grid.Row="1"
              ColumnDefinitions="44,*"
              RowDefinitions="Auto,Auto,Auto"
              Margin="12,4,16,8">

            <!-- Row 0: White filled node + Current Location label -->
            <Ellipse Grid.Row="0" Grid.Column="0"
                     WidthRequest="10" HeightRequest="10"
                     Fill="White"
                     HorizontalOptions="Center"
                     VerticalOptions="Center" />
            <Label Grid.Row="0" Grid.Column="1"
                   Text="{Binding CurrentLocationText}"
                   TextColor="White"
                   FontSize="14"
                   Margin="4,12,0,12"
                   VerticalOptions="Center" />

            <!-- Row 1: Vertical connector line -->
            <BoxView Grid.Row="1" Grid.Column="0"
                     WidthRequest="2"
                     HeightRequest="18"
                     Color="#C8B8E8"
                     Opacity="0.85"
                     HorizontalOptions="Center"
                     VerticalOptions="Fill" />

            <!-- Row 2: Semi-transparent node + search input field -->
            <Ellipse Grid.Row="2" Grid.Column="0"
                     WidthRequest="10" HeightRequest="10"
                     Fill="Transparent"
                     Stroke="White"
                     StrokeThickness="2"
                     Opacity="0.7"
                     HorizontalOptions="Center"
                     VerticalOptions="Center" />
            <Border Grid.Row="2" Grid.Column="1"
                    BackgroundColor="#EDE7F6"
                    StrokeShape="RoundRectangle 24"
                    Stroke="Transparent"
                    Padding="14,8"
                    Margin="4,4,0,4">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Label Grid.Column="0"
                           Text="search"
                           FontFamily="MaterialSymbols"
                           FontSize="15"
                           TextColor="#7B3FA0"
                           VerticalOptions="Center" />
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Text="{Binding DestinationQuery}"
                           Placeholder="Search destination..."
                           PlaceholderColor="#6E6A86"
                           TextColor="#1A0F35"
                           ReturnCommand="{Binding SearchDestinationCommand}"
                           ReturnType="Search"
                           TextChanged="OnSearchTextChanged"
                           MaxLength="200"
                           Margin="8,0,0,0" />
                    <ActivityIndicator Grid.Column="2"
                                       IsRunning="{Binding IsSearchingDestination}"
                                       IsVisible="{Binding IsSearchingDestination}"
                                       Color="#7B3FA0"
                                       WidthRequest="20"
                                       HeightRequest="20"
                                       VerticalOptions="Center"
                                       Margin="6,0,0,0" />
                </Grid>
            </Border>
        </Grid>

        <!-- Results area -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="0,4,0,32">

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         Color="#4A3570"
                         Margin="16,0,16,4"
                         Opacity="0.8" />

                <!-- Recent searches — only shown while the box is empty (ShowRecentSearches). Tapping a row
                     re-selects that destination through the same handler as a live result. Capped at 5 in
                     the controller, so this list never grows past a handful of rows. -->
                <VerticalStackLayout IsVisible="{Binding ShowRecentSearches}"
                                     Spacing="0">
                    <Label Text="Recent Searches"
                           TextColor="#C0A8E8"
                           FontSize="12"
                           FontAttributes="Bold"
                           Margin="16,8,16,2" />
                    <CollectionView ItemsSource="{Binding RecentSearches}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="services:GeocodingResult">
                                <Grid ColumnDefinitions="Auto,*"
                                      Padding="16,10"
                                      BackgroundColor="Transparent">

                                    <Border Grid.Column="0"
                                            BackgroundColor="#3D2B5E"
                                            StrokeShape="Ellipse"
                                            Stroke="Transparent"
                                            WidthRequest="44"
                                            HeightRequest="44">
                                        <Label Text="history"
                                               FontFamily="MaterialSymbols"
                                               FontSize="18"
                                               TextColor="#C8B8E8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Margin="14,0,0,0"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}"
                                               TextColor="White"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2" />
                                        <Label Text="{Binding PlaceType}"
                                               TextColor="#D4C4F0"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label"
                                                             Binding="{Binding PlaceType}"
                                                             Value="{x:Null}">
                                                    <Setter Property="IsVisible" Value="False" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnResultTapped" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Search results list -->
                <CollectionView ItemsSource="{Binding SearchResults}"
                                IsVisible="{Binding HasSearchResults}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="services:GeocodingResult">
                            <Grid ColumnDefinitions="Auto,*"
                                  Padding="16,10"
                                  BackgroundColor="Transparent">

                                <Border Grid.Column="0"
                                        BackgroundColor="#5A3A8A"
                                        StrokeShape="Ellipse"
                                        Stroke="Transparent"
                                        WidthRequest="44"
                                        HeightRequest="44">
                                    <Label Text="&#8599;"
                                           FontSize="18"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </Border>

                                <VerticalStackLayout Grid.Column="1"
                                                     Margin="14,0,0,0"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}"
                                           TextColor="White"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           LineBreakMode="WordWrap"
                                           MaxLines="2" />
                                    <Label Text="{Binding PlaceType}"
                                           TextColor="#D4C4F0"
                                           FontSize="11"
                                           LineBreakMode="TailTruncation">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding PlaceType}"
                                                         Value="{x:Null}">
                                                <Setter Property="IsVisible" Value="False" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </VerticalStackLayout>

                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnResultTapped" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- No results hint -->
                <Label IsVisible="{Binding ShowNoResults}"
                       Text="{Binding LastActionText}"
                       TextColor="#D4C4F0"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       HorizontalOptions="Fill"
                       Margin="24,32" />

                <!-- Result count when results are showing -->
                <Label IsVisible="{Binding HasSearchResults}"
                       Text="{Binding LastActionText}"
                       TextColor="#C0A8E8"
                       FontSize="11"
                       HorizontalOptions="Center"
                       Margin="16,4" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
