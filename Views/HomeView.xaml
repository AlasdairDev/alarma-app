<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controllers="clr-namespace:AlarmaApp.Controllers"
             xmlns:models="clr-namespace:AlarmaApp.Models"
             x:Class="AlarmaApp.Views.HomeView"
             x:DataType="controllers:HomeController"
             x:Name="HomePage"
             Title="Alarma">
    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="24">
            <Label Text="Alarma" FontSize="32" FontAttributes="Bold" />
            <Label Text="Offline-first Android alarm and safety scaffold." FontSize="14" TextColor="#666666" />
            <Label Text="{Binding StatusText}" FontSize="16" />
            <Label Text="{Binding ConnectivityText}" FontSize="14" />
            <Label Text="{Binding OnboardingStatusText}" FontSize="12" TextColor="#888888" />

            <Frame BorderColor="#E0E0E0" Padding="16" IsVisible="{Binding ShowOnboardingPrompt}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Get started" FontAttributes="Bold" />
                    <Label Text="Add an emergency contact and confirm your alarm settings." FontSize="12" TextColor="#666666" />
                    <Button Text="Mark onboarding complete" Command="{Binding CompleteOnboardingCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Alarm settings" FontAttributes="Bold" />
                    <Label Text="Alarm sound" FontSize="12" TextColor="#666666" />
                    <Picker ItemsSource="{Binding AlarmSoundOptions}" SelectedItem="{Binding AlarmSound}" />
                    <Label Text="{Binding AlarmLeadMinutes, StringFormat='Alarm lead time: {0:F0} minutes'}" FontSize="12" />
                    <Stepper Minimum="1" Maximum="60" Increment="1" Value="{Binding AlarmLeadMinutes}" />
                    <HorizontalStackLayout Spacing="12">
                        <Label Text="Vibration-only mode" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding VibrationOnly}" />
                    </HorizontalStackLayout>
                    <Button Text="Initialize Local Database" Command="{Binding InitializeCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Destination" FontAttributes="Bold" />
                    <Entry Placeholder="Destination search query" Text="{Binding DestinationQuery}" />
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Search Destination" Command="{Binding SearchDestinationCommand}" />
                        <Button Text="Save Route" Command="{Binding SaveDestinationCommand}" IsEnabled="{Binding CanSaveRoute}" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding DestinationSummaryText}" FontSize="12" TextColor="#666666" />
                    <Image Source="{Binding MapTileSource}"
                           HeightRequest="180"
                           WidthRequest="180"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasMapTile}" />
                    <Button Text="Open Google Maps Reroute" Command="{Binding OpenMapsCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Trip tracking" FontAttributes="Bold" />
                    <Label Text="{Binding TrackingStatusText}" FontSize="14" TextColor="#666666" />
                    <Label Text="{Binding DistanceToDestinationText}" FontSize="12" TextColor="#666666" />
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Start Trip Tracking" Command="{Binding StartTrackingCommand}" IsEnabled="{Binding IsNotTracking}" />
                        <Button Text="Stop Trip Tracking" Command="{Binding StopTrackingCommand}" IsEnabled="{Binding IsTracking}" />
                    </HorizontalStackLayout>
                    <Button Text="Send Test SOS SMS" Command="{Binding SendTestSmsCommand}" IsEnabled="{Binding CanSendSos}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Availability &amp; device status" FontAttributes="Bold" />
                    <Label Text="{Binding AvailabilityStatusText}" FontSize="12" TextColor="#666666" />
                    <Button Text="Refresh availability" Command="{Binding RefreshAvailabilityCommand}" />
                    <Label Text="{Binding EarphoneStatusText}" FontSize="12" TextColor="#666666" />
                    <Button Text="Check earphone connection" Command="{Binding RefreshEarphoneStatusCommand}" />
                    <Label Text="{Binding BatteryOptimizationStatusText}" FontSize="12" TextColor="#666666" />
                    <Button Text="Allow battery optimization ignore" Command="{Binding RequestBatteryOptimizationCommand}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Emergency contacts" FontAttributes="Bold" />
                    <Entry Placeholder="Contact name" Text="{Binding NewContactName}" />
                    <Entry Placeholder="Phone number" Text="{Binding NewContactNumber}" Keyboard="Telephone" />
                    <Button Text="Add contact" Command="{Binding AddEmergencyContactCommand}" />
                    <CollectionView ItemsSource="{Binding EmergencyContacts}">
                        <CollectionView.EmptyView>
                            <Label Text="No emergency contacts saved yet." FontSize="12" TextColor="#888888" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:EmergencyContact">
                                <VerticalStackLayout Spacing="6" Padding="8" BackgroundColor="#F7F7F7">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" />
                                    <Label Text="{Binding PhoneNumber}" FontSize="12" TextColor="#666666" />
                                    <Label Text="Primary contact" FontSize="12" TextColor="#1B1F3B" IsVisible="{Binding IsPrimary}" />
                                    <HorizontalStackLayout Spacing="12">
                                        <Button Text="Set Primary"
                                                Command="{Binding BindingContext.SetPrimaryContactCommand, Source={x:Reference HomePage}}"
                                                CommandParameter="{Binding .}" />
                                        <Button Text="Remove"
                                                Command="{Binding BindingContext.RemoveEmergencyContactCommand, Source={x:Reference HomePage}}"
                                                CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Saved routes (up to 5)" FontAttributes="Bold" />
                    <Entry Placeholder="Optional route name" Text="{Binding NewRouteName}" />
                    <Button Text="Save last destination" Command="{Binding SaveDestinationCommand}" IsEnabled="{Binding CanSaveRoute}" />
                    <CollectionView ItemsSource="{Binding SavedRoutes}">
                        <CollectionView.EmptyView>
                            <Label Text="No saved routes yet." FontSize="12" TextColor="#888888" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SavedRoute">
                                <VerticalStackLayout Spacing="6" Padding="8" BackgroundColor="#F7F7F7">
                                    <Label Text="{Binding Name}" FontAttributes="Bold" />
                                    <Label Text="{Binding Notes}" FontSize="12" TextColor="#666666" />
                                    <HorizontalStackLayout Spacing="12">
                                        <Button Text="Use"
                                                Command="{Binding BindingContext.ApplySavedRouteCommand, Source={x:Reference HomePage}}"
                                                CommandParameter="{Binding .}" />
                                        <Button Text="Remove"
                                                Command="{Binding BindingContext.RemoveSavedRouteCommand, Source={x:Reference HomePage}}"
                                                CommandParameter="{Binding .}" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Backup &amp; export" FontAttributes="Bold" />
                    <Label Text="{Binding LastBackupText}" FontSize="12" TextColor="#666666" />
                    <HorizontalStackLayout Spacing="12">
                        <Button Text="Export backup" Command="{Binding ExportBackupCommand}" />
                        <Button Text="Restore latest" Command="{Binding RestoreBackupCommand}" IsEnabled="{Binding HasBackupAvailable}" />
                    </HorizontalStackLayout>
                    <Label Text="{Binding BackupStatusText}" FontSize="12" TextColor="#666666" />
                </VerticalStackLayout>
            </Frame>

            <Frame BorderColor="#E0E0E0" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Trip history (last 20)" FontAttributes="Bold" />
                    <CollectionView ItemsSource="{Binding TripHistoryEntries}">
                        <CollectionView.EmptyView>
                            <Label Text="No trip history yet." FontSize="12" TextColor="#888888" />
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TripHistory">
                                <VerticalStackLayout Spacing="4" Padding="8" BackgroundColor="#F7F7F7">
                                    <Label Text="{Binding DestinationName}" FontAttributes="Bold" />
                                    <Label Text="{Binding StartedAt, StringFormat='Started {0:g}'}" FontSize="12" TextColor="#666666" />
                                    <Label Text="{Binding Summary}" FontSize="12" TextColor="#666666" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding LastActionText}" FontSize="12" TextColor="#888888" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>