<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.HistoryView"
             x:Name="HistoryPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill" RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Title -->
        <Label Grid.Row="0"
               Text="Trip History"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="White"
               Padding="24,52,24,8"
               BackgroundColor="#1A0F35" />

        <!-- Search pill — a fully-rounded lavender bar matching the Home destination pill (#EDE7F6).
             The inner Entry is transparent and has its native underline stripped in code-behind so the
             whole thing reads as one seamless pill. Filters the list live as you type. -->
        <Border Grid.Row="1"
                BackgroundColor="#EDE7F6"
                StrokeShape="RoundRectangle 25"
                Stroke="Transparent"
                Margin="16,0,16,10"
                Padding="16,4">
            <Grid ColumnDefinitions="Auto,*">
                <Label Grid.Column="0"
                       Text="search"
                       FontFamily="MaterialSymbols"
                       FontSize="16"
                       TextColor="#7B3FA0"
                       VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       x:Name="SearchEntry"
                       HandlerChanged="OnSearchEntryHandlerChanged"
                       Text="{Binding HistorySearchQuery, Mode=TwoWay}"
                       Placeholder="Search by destination, route, or date"
                       PlaceholderColor="#8A7AAE"
                       TextColor="#3D2B5E"
                       BackgroundColor="Transparent"
                       FontSize="14"
                       MaxLength="200"
                       ClearButtonVisibility="WhileEditing"
                       Margin="8,0,0,0"
                       VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- Tappable filter chips — quick categories on top of the free-text search. Active chip lights
             up lavender via the inline DataTrigger comparing HistoryFilterCategory to its own value. -->
        <ScrollView Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Margin="0,0,0,10">
            <HorizontalStackLayout Spacing="8" Padding="16,0">
                <Button Text="All"
                        Command="{Binding SetHistoryFilterCommand}"
                        CommandParameter="All"
                        BackgroundColor="#3D2B5E"
                        TextColor="#C8B8E8"
                        FontSize="13"
                        CornerRadius="20"
                        Padding="18,8"
                        SemanticProperties.Hint="Show all trips">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding HistoryFilterCategory}" Value="All">
                            <Setter Property="BackgroundColor" Value="#EDE7F6" />
                            <Setter Property="TextColor" Value="#4A2E73" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="Recent"
                        Command="{Binding SetHistoryFilterCommand}"
                        CommandParameter="Recent"
                        BackgroundColor="#3D2B5E"
                        TextColor="#C8B8E8"
                        FontSize="13"
                        CornerRadius="20"
                        Padding="18,8"
                        SemanticProperties.Hint="Show trips from the last 7 days">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding HistoryFilterCategory}" Value="Recent">
                            <Setter Property="BackgroundColor" Value="#EDE7F6" />
                            <Setter Property="TextColor" Value="#4A2E73" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Text="By Route"
                        Command="{Binding SetHistoryFilterCommand}"
                        CommandParameter="By Route"
                        BackgroundColor="#3D2B5E"
                        TextColor="#C8B8E8"
                        FontSize="13"
                        CornerRadius="20"
                        Padding="18,8"
                        SemanticProperties.Hint="Sort trips alphabetically by destination route">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding HistoryFilterCategory}" Value="By Route">
                            <Setter Property="BackgroundColor" Value="#EDE7F6" />
                            <Setter Property="TextColor" Value="#4A2E73" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- Clear All — sits under the filters so it can act on whatever the search + chips currently
             show. Hidden when the (filtered) list is empty. -->
        <Button Grid.Row="3"
                Text="Clear All"
                IsVisible="{Binding HasTripHistory}"
                Clicked="OnClearAllClicked"
                HorizontalOptions="End"
                BackgroundColor="#4A1A1A"
                TextColor="#FF6B6B"
                FontSize="13"
                FontAttributes="Bold"
                CornerRadius="18"
                Padding="16,6"
                Margin="16,0,16,8"
                SemanticProperties.Description="Clear shown trip history"
                SemanticProperties.Hint="Double tap to delete the trips currently shown in the list" />

        <!-- Trip list -->
        <ScrollView Grid.Row="4">
            <VerticalStackLayout Spacing="0">

                <!-- Empty state -->
                <Label IsVisible="{Binding HasNoTripHistory}"
                       Text="No trips recorded yet."
                       TextColor="#8A7AAE"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,48" />

                <!-- History entries -->
                <CollectionView ItemsSource="{Binding TripHistoryEntries}"
                                IsVisible="{Binding HasTripHistory}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Swipe left for a Delete action; the trash icon in the card does the same on tap. -->
                            <SwipeView Margin="16,6">
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItem Text="Delete"
                                                   BackgroundColor="#B00020"
                                                   Command="{Binding Source={x:Reference HistoryPage}, Path=BindingContext.DeleteTripHistoryCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border BackgroundColor="#261C40"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="Transparent"
                                    Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="8">

                                    <!-- Departure → Destination row -->
                                    <Grid ColumnDefinitions="*,Auto,*">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="Departure"
                                                   FontSize="11"
                                                   TextColor="#8A7AAE" />
                                            <Label Text="{Binding StartedAt, StringFormat='{0:h:mm tt}'}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="&#8594;"
                                               FontSize="14"
                                               TextColor="#8A7AAE"
                                               VerticalOptions="End"
                                               Margin="8,0" />
                                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                                            <Label Text="Arrival"
                                                   FontSize="11"
                                                   TextColor="#8A7AAE" />
                                            <Label Text="{Binding DestinationName}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- Badges row -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Border IsVisible="{Binding HasAlarmStage}"
                                                BackgroundColor="#7A3200"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="{Binding AlarmStageBadgeText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#FF8C00" />
                                        </Border>
                                        <Border BackgroundColor="#1E5C3A"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="{Binding DistanceKmText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#4CD964" />
                                        </Border>
                                        <Border BackgroundColor="#0F3A3A"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="{Binding DurationText}"
                                                   FontSize="11"
                                                   TextColor="#4DD0C4" />
                                        </Border>
                                        <Border IsVisible="{Binding OvershootDetected}"
                                                BackgroundColor="#4A1A00"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="Missed Stop"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#FF9500" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <!-- Date row -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="calendar_month" FontFamily="MaterialSymbols"
                                               FontSize="12"
                                               TextColor="#8A7AAE"
                                               VerticalOptions="Center" />
                                        <Label Text="{Binding StartedAt, StringFormat='{0:MMMM d, yyyy}'}"
                                               FontSize="12"
                                               TextColor="#8A7AAE"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                                <!-- Trash icon — routes through a confirm prompt before deleting (the swipe
                                     action still uses the raw command). -->
                                <Button Grid.Column="1"
                                        Text="delete"
                                        FontFamily="MaterialSymbols"
                                        FontSize="20"
                                        BackgroundColor="Transparent"
                                        TextColor="#A88FD0"
                                        Padding="8,0,0,0"
                                        VerticalOptions="Start"
                                        Clicked="OnDeleteTripClicked"
                                        CommandParameter="{Binding .}"
                                        SemanticProperties.Description="Delete this trip"
                                        SemanticProperties.Hint="Double tap to remove this trip from history" />
                                </Grid>
                            </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="24" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
