<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.HistoryView"
             x:Name="HistoryPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Title -->
        <Label Grid.Row="0"
               Text="Trip History"
               FontSize="28"
               FontAttributes="Bold"
               TextColor="White"
               Padding="24,52,24,8"
               BackgroundColor="#1A0F35" />

        <!-- Search bar — filters the list live as you type (destination, route details, or date/time). -->
        <SearchBar Grid.Row="1"
                   Text="{Binding HistorySearchQuery, Mode=TwoWay}"
                   Placeholder="Search trips by destination, route, or date"
                   PlaceholderColor="#8A7AAE"
                   TextColor="White"
                   CancelButtonColor="#A88FD0"
                   BackgroundColor="#3D2B5E"
                   MaxLength="200"
                   Margin="16,0,16,8"
                   SemanticProperties.Description="Search trip history"
                   SemanticProperties.Hint="Type to filter trips by destination, route, or date" />

        <!-- Clear All — sits under the search so it can act on whatever the filter currently shows.
             Hidden when the (filtered) list is empty. -->
        <Button Grid.Row="2"
                Text="Clear All"
                IsVisible="{Binding HasTripHistory}"
                Clicked="OnClearAllClicked"
                HorizontalOptions="End"
                BackgroundColor="#4A1A1A"
                TextColor="#FF6B6B"
                FontSize="13"
                FontAttributes="Bold"
                CornerRadius="18"
                Padding="16,6"
                Margin="16,0,16,8"
                SemanticProperties.Description="Clear shown trip history"
                SemanticProperties.Hint="Double tap to delete the trips currently shown in the list" />

        <!-- Trip list -->
        <ScrollView Grid.Row="3">
            <VerticalStackLayout Spacing="0">

                <!-- Empty state -->
                <Label IsVisible="{Binding HasNoTripHistory}"
                       Text="No trips recorded yet."
                       TextColor="#8A7AAE"
                       FontSize="14"
                       HorizontalOptions="Center"
                       Margin="0,48" />

                <!-- History entries -->
                <CollectionView ItemsSource="{Binding TripHistoryEntries}"
                                IsVisible="{Binding HasTripHistory}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <!-- Swipe left for a Delete action; the trash icon in the card does the same on tap. -->
                            <SwipeView Margin="16,6">
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Execute">
                                        <SwipeItem Text="Delete"
                                                   BackgroundColor="#B00020"
                                                   Command="{Binding Source={x:Reference HistoryPage}, Path=BindingContext.DeleteTripHistoryCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>
                                <Border BackgroundColor="#261C40"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="Transparent"
                                    Padding="16,14">
                                <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="8">

                                    <!-- Departure → Destination row -->
                                    <Grid ColumnDefinitions="*,Auto,*">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="Departure"
                                                   FontSize="11"
                                                   TextColor="#8A7AAE" />
                                            <Label Text="{Binding StartedAt, StringFormat='{0:h:mm tt}'}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1"
                                               Text="&#8594;"
                                               FontSize="14"
                                               TextColor="#8A7AAE"
                                               VerticalOptions="End"
                                               Margin="8,0" />
                                        <VerticalStackLayout Grid.Column="2" Spacing="2">
                                            <Label Text="Arrival"
                                                   FontSize="11"
                                                   TextColor="#8A7AAE" />
                                            <Label Text="{Binding DestinationName}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- Badges row -->
                                    <HorizontalStackLayout Spacing="8">
                                        <Border IsVisible="{Binding HasAlarmStage}"
                                                BackgroundColor="#7A3200"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="{Binding AlarmStageBadgeText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#FF8C00" />
                                        </Border>
                                        <Border BackgroundColor="#1E5C3A"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="{Binding DistanceKmText}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#4CD964" />
                                        </Border>
                                        <Border BackgroundColor="#0F3A3A"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="{Binding DurationText}"
                                                   FontSize="11"
                                                   TextColor="#4DD0C4" />
                                        </Border>
                                        <Border IsVisible="{Binding OvershootDetected}"
                                                BackgroundColor="#4A1A00"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                Padding="10,4">
                                            <Label Text="Missed Stop"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#FF9500" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <!-- Date row -->
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="calendar_month" FontFamily="MaterialSymbols"
                                               FontSize="12"
                                               TextColor="#8A7AAE"
                                               VerticalOptions="Center" />
                                        <Label Text="{Binding StartedAt, StringFormat='{0:MMMM d, yyyy}'}"
                                               FontSize="12"
                                               TextColor="#8A7AAE"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>

                                <!-- Trash icon — same delete command as the swipe action -->
                                <Button Grid.Column="1"
                                        Text="delete"
                                        FontFamily="MaterialSymbols"
                                        FontSize="20"
                                        BackgroundColor="Transparent"
                                        TextColor="#A88FD0"
                                        Padding="8,0,0,0"
                                        VerticalOptions="Start"
                                        Command="{Binding Source={x:Reference HistoryPage}, Path=BindingContext.DeleteTripHistoryCommand}"
                                        CommandParameter="{Binding .}"
                                        SemanticProperties.Description="Delete this trip"
                                        SemanticProperties.Hint="Double tap to remove this trip from history" />
                                </Grid>
                            </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <BoxView HeightRequest="24" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
