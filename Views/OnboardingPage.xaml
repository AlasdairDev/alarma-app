<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.OnboardingPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#0F0822">

    <Grid>
        <!-- The current slide is a full-design PNG. It has no gesture, so it silently absorbs
             taps everywhere except the button zones (no carousel = no screen-wide click sound). -->
        <Image x:Name="SlideImage"
               Aspect="AspectFill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />

        <!-- Tap zones aligned over the baked-in Skip / Next pills -->
        <Grid VerticalOptions="End"
              Margin="32,0,32,52"
              HeightRequest="56"
              ColumnDefinitions="*,*"
              ColumnSpacing="16">
            <Grid Grid.Column="0" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSkipTapped" />
                </Grid.GestureRecognizers>
            </Grid>
            <Grid Grid.Column="1" BackgroundColor="Transparent">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNextTapped" />
                </Grid.GestureRecognizers>
            </Grid>
        </Grid>

        <!-- SLIDE 4 TERMS POPUP: a modal scrim (absorbs taps, no sound) + agreement card -->
        <Grid x:Name="TermsPopup"
              IsVisible="False"
              BackgroundColor="#CC000000"
              ZIndex="100">
            <Border VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Margin="28"
                    BackgroundColor="#1E1533"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 24"
                    Padding="24,28,24,24">
                <VerticalStackLayout Spacing="18">
                    <Label Text="Almost there"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center" />

                    <Label FontSize="13" HorizontalTextAlignment="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="Read our " TextColor="#A098B0" />
                                <Span Text="Privacy Policy"
                                      TextColor="#C39BE8"
                                      TextDecorations="Underline">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnPrivacyPolicyLinkTapped" />
                                    </Span.GestureRecognizers>
                                </Span>
                                <Span Text=" and " TextColor="#A098B0" />
                                <Span Text="Terms &amp; Conditions"
                                      TextColor="#C39BE8"
                                      TextDecorations="Underline">
                                    <Span.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnTermsLinkTapped" />
                                    </Span.GestureRecognizers>
                                </Span>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>

                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <CheckBox x:Name="AgreeCheckBox"
                                  Color="#8A2BE2"
                                  CheckedChanged="OnAgreeCheckChanged"
                                  VerticalOptions="Center" />
                        <Label Text="I have read and agree to the Privacy Policy and T&amp;C"
                               FontSize="13"
                               TextColor="#C8B8E8"
                               VerticalOptions="Center"
                               MaximumWidthRequest="220"
                               LineBreakMode="WordWrap" />
                    </HorizontalStackLayout>

                    <Button Text="Get Started"
                            BackgroundColor="#8A2BE2"
                            TextColor="White"
                            CornerRadius="25"
                            HeightRequest="52"
                            FontAttributes="Bold"
                            Clicked="OnGetStartedClicked" />

                    <Label Text="Maybe later"
                           FontSize="13"
                           TextColor="#A098B0"
                           HorizontalTextAlignment="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseTermsTapped" />
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
