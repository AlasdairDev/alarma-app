<?xml version="1.0" encoding="utf-8" ?>
<!-- Security (OWASP)
     A04 Insecure Design: IsOvershootPending / IsOvershootConfirmed are controller-driven server-side
       state — the UI only renders them; no user input can set them directly.
     A03 Injection: All JS forwarded via MapJsRequested uses InvariantCulture F6 numeric strings or
       JsonSerializer.Serialize — no user-supplied text reaches EvaluateJavaScriptAsync. -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.AlarmStageView"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
        <!-- Map background -->
        <WebView x:Name="AlarmMapWebView"
                 Source="{Binding MapHtmlSource}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- Stage 3 WAKE UP red tint — hidden during overshoot dialogs (Figma 17 has clear map) -->
        <BoxView BackgroundColor="#881A0000"
                 IsVisible="{Binding IsStage3Wake}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- Stage label (top centre) -->
        <Label Text="{Binding AlarmStageLabel}"
               FontSize="18"
               FontAttributes="Italic"
               TextColor="White"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="0,56,0,0" />

        <!-- Distance + destination name chip -->
        <Border HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,86,0,0"
                BackgroundColor="#3D2B5E"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                Padding="16,8">
            <HorizontalStackLayout Spacing="8">
                <Label Text="&#128205;"
                       FontSize="14"
                       TextColor="#9B6FBF"
                       VerticalOptions="Center" />
                <VerticalStackLayout Spacing="1"
                                     VerticalOptions="Center">
                    <Label Text="{Binding DistanceToDestinationText}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="{Binding DestinationShortNameText}"
                           FontSize="11"
                           TextColor="#C8B8E8"
                           IsVisible="{Binding IsTracking}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Bottom card background -->
        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="#F21A0F35"
                StrokeShape="RoundRectangle 0"
                Stroke="Transparent"
                HeightRequest="300" />

        <!-- ── Stage 1 / 2 content ──────────────────────────────────── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="10"
                             IsVisible="{Binding IsStage1Or2Active}">

            <Label Text="{Binding AlarmStageTitle}"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding AlarmStageBody}"
                   FontSize="16"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Slide to Stop pill -->
            <Border BackgroundColor="#4A3570"
                    StrokeShape="RoundRectangle 28"
                    Stroke="#6A5590"
                    StrokeThickness="1"
                    Padding="8"
                    Margin="0,10,0,0">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Label Text="&#10006;"
                               FontSize="18"
                               TextColor="#4A3570"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Grid.Column="1"
                           Text="Slide to Stop"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSlideToStopTapped" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Snooze button (Stage 1/2 only; command no-ops on Stage 3) -->
            <Button Text="Snooze"
                    BackgroundColor="#3D2B5E"
                    TextColor="#C8B8E8"
                    FontSize="14"
                    CornerRadius="20"
                    Padding="0,10"
                    Command="{Binding SnoozeAlarmCommand}"
                    Margin="0,4,0,0" />

            <!-- Reminder checklist (Stage 1 only) — matches Figma 14 -->
            <VerticalStackLayout Spacing="8"
                                 Margin="0,8,0,0"
                                 IsVisible="{Binding IsStage1Active}">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="&#10003;"
                           FontSize="16"
                           TextColor="#4CD964"
                           VerticalOptions="Center" />
                    <Label Text="Gather belongings"
                           FontSize="14"
                           TextColor="#C8B8E8"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <Label Text="&#10003;"
                           FontSize="16"
                           TextColor="#4CD964"
                           VerticalOptions="Center" />
                    <Label Text="Stay alert"
                           FontSize="14"
                           TextColor="#C8B8E8"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ── Stage 3 — WAKE UP (Figma 16) ───────────────────────────── -->
        <!-- Only when Stage3 fires but overshoot dialog is NOT showing -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="10"
                             IsVisible="{Binding IsStage3Wake}">

            <Label Text="{Binding AlarmStageTitle}"
                   FontSize="48"
                   FontAttributes="Bold"
                   TextColor="#FF3B30"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding AlarmStageBody}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Slide to Dismiss (red) — Figma 16 -->
            <Border BackgroundColor="#CC1A0F"
                    StrokeShape="RoundRectangle 28"
                    Stroke="#FF3B30"
                    StrokeThickness="1"
                    Padding="8"
                    Margin="0,14,0,0">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                            BackgroundColor="White"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Label Text="&#10006;"
                               FontSize="18"
                               TextColor="#CC1A0F"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Grid.Column="1"
                           Text="Slide to dismiss"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnSlideToStopTapped" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>

        <!-- ── Overshoot Pending — "Did you miss your stop?" (Figma 17) ── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="12"
                             IsVisible="{Binding IsOvershootPending}">

            <Label Text="Overshoot Detected"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label Text="Did you miss your stop?"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="{Binding OvershootDistanceText, StringFormat='You might have passed your destination by {0}.'}"
                   FontSize="14"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,6,0,0">
                <Button Grid.Column="0"
                        Text="No"
                        BackgroundColor="#3D2B5E"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        Command="{Binding DismissOvershootCommand}" />
                <Button Grid.Column="1"
                        Text="Yes"
                        BackgroundColor="#7B3FA0"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        Command="{Binding ConfirmOvershootCommand}" />
            </Grid>

        </VerticalStackLayout>

        <!-- ── Overshoot Confirmed — "You missed your stop." (Figma 17.5) ── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="12"
                             IsVisible="{Binding IsOvershootConfirmed}">

            <Label Text="Overshoot Detected"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Label Text="You missed your stop."
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="{Binding OvershootDistanceText, StringFormat='You passed your destination by {0}.'}"
                   FontSize="14"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,6,0,0">
                <Button Grid.Column="0"
                        Text="Close"
                        BackgroundColor="#3D2B5E"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        Command="{Binding DismissOvershootCommand}" />
                <Button Grid.Column="1"
                        Text="Open in GMaps"
                        BackgroundColor="#7B3FA0"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        Command="{Binding OpenInGMapsCommand}" />
            </Grid>

        </VerticalStackLayout>

        <!-- ── No alarm active — tracking only ──────────────────────────── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="10"
                             IsVisible="{Binding IsNotAlarmActive}">

            <Label Text="{Binding DistanceToDestinationText}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />
            <Label Text="{Binding DestinationSummaryText}"
                   FontSize="14"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   LineBreakMode="TailTruncation" />
            <Button Text="Stop Trip"
                    BackgroundColor="#4A3570"
                    TextColor="White"
                    CornerRadius="24"
                    FontSize="16"
                    Padding="0,14"
                    Clicked="OnStopTripClicked" />

        </VerticalStackLayout>

    </Grid>
</ContentPage>
