<?xml version="1.0" encoding="utf-8" ?>
<!-- The overshoot flags (IsOvershootPending / IsOvershootConfirmed) live on the controller — this
     page only renders them, so nothing the user taps can flip that state on its own. And everything
     we push to the trip map through MapJsRequested is an InvariantCulture F6 number or JsonSerializer
     output, so no raw user text ever reaches EvaluateJavaScriptAsync. -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlarmaApp.Views.AlarmStageView"
             Shell.NavBarIsVisible="False"
             Shell.TabBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill">
        <!-- Map background -->
        <WebView x:Name="AlarmMapWebView"
                 Source="{Binding MapHtmlSource}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- Stage 3 WAKE UP red tint — hidden during overshoot dialogs (Figma 17 has clear map) -->
        <BoxView BackgroundColor="#881A0000"
                 IsVisible="{Binding IsStage3Wake}"
                 HorizontalOptions="Fill"
                 VerticalOptions="Fill" />

        <!-- Stage label (top centre) — shows "Overshoot Detected" during overshoot states -->
        <Label Text="{Binding TopStatusLabel}"
               FontSize="18"
               FontAttributes="Italic"
               TextColor="White"
               HorizontalOptions="Center"
               VerticalOptions="Start"
               Margin="0,56,0,0" />

        <!-- Distance + destination name chip — hidden during pure Stage 3 Wake Up (Figma 16) -->
        <Border HorizontalOptions="Center"
                VerticalOptions="Start"
                Margin="0,86,0,0"
                BackgroundColor="#3D2B5E"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                Padding="16,8"
                IsVisible="{Binding IsChipVisible}">
            <HorizontalStackLayout Spacing="8">
                <Label Text="location_on" FontFamily="MaterialSymbols"
                       FontSize="14"
                       TextColor="#9B6FBF"
                       VerticalOptions="Center" />
                <VerticalStackLayout Spacing="1"
                                     VerticalOptions="Center">
                    <Label Text="{Binding ChipDistanceText}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="{Binding DestinationShortNameText}"
                           FontSize="11"
                           TextColor="#C8B8E8"
                           IsVisible="{Binding IsTracking}" />
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- Bottom card background -->
        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="#F21A0F35"
                StrokeShape="RoundRectangle 0"
                Stroke="Transparent"
                HeightRequest="300" />

        <!-- ── Stage 1 / 2 content ──────────────────────────────────── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="10"
                             IsVisible="{Binding IsStage1Or2Active}">

            <Label Text="{Binding AlarmStageTitle}"
                   FontSize="30"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding AlarmStageBody}"
                   FontSize="16"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Slide to Stop pill — PanGestureRecognizer requires actual swipe to dismiss -->
            <Border x:Name="SlideToStopPill"
                    BackgroundColor="#4A3570"
                    StrokeShape="RoundRectangle 28"
                    Stroke="#6A5590"
                    StrokeThickness="1"
                    Padding="8"
                    Margin="0,10,0,0"
                    SemanticProperties.Description="Slide to stop alarm"
                    SemanticProperties.Hint="Swipe right across the pill to dismiss the alarm and stop the trip">
                <Grid x:Name="SlideToStopTrack" ColumnDefinitions="Auto,*">
                    <Border x:Name="SlideToStopThumb"
                            Grid.Column="0"
                            BackgroundColor="White"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Label Text="&#8250;"
                               FontSize="22"
                               TextColor="#4A3570"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Grid.Column="1"
                           Text="Slide to Stop"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnSlideToStopPanUpdated" />
                </Border.GestureRecognizers>
            </Border>

            <!-- Reminder checklist (Stage 1 only) — matches Figma 14 -->
            <VerticalStackLayout Spacing="8"
                                 Margin="0,8,0,0"
                                 IsVisible="{Binding IsStage1Active}">
                <HorizontalStackLayout Spacing="10">
                    <Border BackgroundColor="#4CD964"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            WidthRequest="22"
                            HeightRequest="22"
                            VerticalOptions="Center">
                        <Label Text="check" FontFamily="MaterialSymbols"
                               FontSize="12"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="Gather belongings"
                           FontSize="14"
                           TextColor="#C8B8E8"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <Border BackgroundColor="#4CD964"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            WidthRequest="22"
                            HeightRequest="22"
                            VerticalOptions="Center">
                        <Label Text="check" FontFamily="MaterialSymbols"
                               FontSize="12"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="Stay alert"
                           FontSize="14"
                           TextColor="#C8B8E8"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>

        <!-- ── Stage 3 — WAKE UP (Figma 16) ───────────────────────────── -->
        <!-- Only when Stage3 fires but overshoot dialog is NOT showing -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="10"
                             IsVisible="{Binding IsStage3Wake}">

            <Label Text="{Binding AlarmStageTitle}"
                   FontSize="48"
                   FontAttributes="Bold"
                   TextColor="#FF3B30"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding AlarmStageBody}"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <!-- Slide to Dismiss (red) — PanGestureRecognizer requires actual swipe (Figma 16) -->
            <Border x:Name="SlideToDismissPill"
                    BackgroundColor="#CC1A0F"
                    StrokeShape="RoundRectangle 28"
                    Stroke="#FF3B30"
                    StrokeThickness="1"
                    Padding="8"
                    Margin="0,14,0,0"
                    SemanticProperties.Description="Slide to dismiss WAKE UP alarm"
                    SemanticProperties.Hint="Swipe right across the pill to dismiss the critical wake-up alarm">
                <Grid x:Name="SlideToDismissTrack" ColumnDefinitions="Auto,*">
                    <Border x:Name="SlideToDismissThumb"
                            Grid.Column="0"
                            BackgroundColor="White"
                            StrokeShape="Ellipse"
                            Stroke="Transparent"
                            WidthRequest="44"
                            HeightRequest="44">
                        <Label Text="&#8250;"
                               FontSize="22"
                               TextColor="#CC1A0F"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Grid.Column="1"
                           Text="Slide to dismiss"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>
                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnSlideToDismissPanUpdated" />
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>

        <!-- ── Overshoot Pending — "Did you miss your stop?" (Figma 17) ── -->
        <!-- "Overshoot Detected" header now rendered by TopStatusLabel in the top label -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="12"
                             IsVisible="{Binding IsOvershootPending}">

            <Label Text="Did you miss your stop?"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="{Binding OvershootDistanceText, StringFormat='You might have passed your destination by {0}.'}"
                   FontSize="14"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12"
                  Margin="0,6,0,0">
                <Button Grid.Column="0"
                        Text="No"
                        BackgroundColor="#3D2B5E"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        SemanticProperties.Description="No, I did not miss my stop"
                        SemanticProperties.Hint="Double tap to dismiss the overshoot warning"
                        Command="{Binding DismissOvershootCommand}" />
                <Button Grid.Column="1"
                        Text="Yes"
                        BackgroundColor="#7B3FA0"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        SemanticProperties.Description="Yes, I missed my stop"
                        SemanticProperties.Hint="Double tap to confirm you passed your destination"
                        Command="{Binding ConfirmOvershootCommand}" />
            </Grid>

        </VerticalStackLayout>

        <!-- ── Overshoot Confirmed — full-screen alert: destination name + exact distance passed ── -->
        <!-- "Overshoot Detected" header now rendered by TopStatusLabel in the top label -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,48"
                             Spacing="10"
                             IsVisible="{Binding IsOvershootConfirmed}">

            <Label Text="You missed your stop."
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <Label Text="{Binding DestinationShortNameText}"
                   FontSize="16"
                   FontAttributes="Bold"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="TailTruncation" />

            <Label Text="{Binding OvershootDistanceText, StringFormat='You have passed your destination by {0}.'}"
                   FontSize="14"
                   TextColor="#C8B8E8"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   LineBreakMode="WordWrap" />

            <Button Text="Open Navigation via Google Maps"
                    BackgroundColor="#7B3FA0"
                    TextColor="White"
                    FontSize="15"
                    FontAttributes="Bold"
                    CornerRadius="24"
                    Padding="0,14"
                    Margin="0,8,0,0"
                    SemanticProperties.Description="Open navigation in Google Maps"
                    SemanticProperties.Hint="Double tap to hand off directions back to your destination to Google Maps"
                    Command="{Binding OpenInGMapsCommand}" />
            <Button Text="Close"
                    BackgroundColor="#3D2B5E"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="24"
                    Padding="0,14"
                    SemanticProperties.Description="Close overshoot alert"
                    SemanticProperties.Hint="Double tap to close and see area safety information"
                    Command="{Binding CloseOvershootCommand}" />

        </VerticalStackLayout>

        <!-- ── Area Safety Alert overlay (shown after Close) ── -->
        <Border IsVisible="{Binding IsAreaSafetyVisible}"
                BackgroundColor="#F21A0F35"
                Stroke="Transparent"
                StrokeShape="RoundRectangle 0"
                HorizontalOptions="Fill"
                VerticalOptions="Fill">
            <VerticalStackLayout VerticalOptions="Center"
                                 HorizontalOptions="Fill"
                                 Padding="28"
                                 Spacing="16">
                <Label Text="warning" FontFamily="MaterialSymbols"
                       FontSize="44"
                       TextColor="#FF9500"
                       HorizontalOptions="Center" />
                <Label Text="Area Safety Alert"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Border BackgroundColor="#3D2B5E"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 16"
                        Padding="18">
                    <Label Text="{Binding AreaSafetyText}"
                           FontSize="14"
                           TextColor="#E8DEF8"
                           LineBreakMode="WordWrap" />
                </Border>
                <Button Text="Continue to Rerouting"
                        BackgroundColor="#7B3FA0"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="24"
                        Padding="0,14"
                        SemanticProperties.Description="Continue to rerouting"
                        SemanticProperties.Hint="Double tap to see step-by-step directions back to your stop"
                        Command="{Binding ContinueToReroutingCommand}" />
            </VerticalStackLayout>
        </Border>

        <!-- ── Rerouting screen — mini-map (the map behind this card) + step-by-step return guidance ── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="24,0,24,40"
                             Spacing="10"
                             IsVisible="{Binding IsReroutingVisible}">
            <Border BackgroundColor="#F21A0F35"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 20"
                    Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Rerouting to your stop"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="{Binding ReroutingHeadingText}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#9B6FBF"
                           LineBreakMode="WordWrap" />
                    <!-- Step-by-step instructions (computed offline from the last fix + destination) -->
                    <VerticalStackLayout Spacing="6"
                                         BindableLayout.ItemsSource="{Binding ReroutingSteps}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}"
                                       FontSize="13"
                                       TextColor="#E8DEF8"
                                       LineBreakMode="WordWrap" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                        <Button Grid.Column="0"
                                Text="Done"
                                BackgroundColor="#3D2B5E"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="24"
                                Padding="0,14"
                                SemanticProperties.Description="Finish rerouting"
                                SemanticProperties.Hint="Double tap to close rerouting and return to the app"
                                Clicked="OnReroutingDoneClicked" />
                        <Button Grid.Column="1"
                                Text="Open in Google Maps"
                                BackgroundColor="#7B3FA0"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="24"
                                Padding="0,14"
                                SemanticProperties.Description="Open navigation in Google Maps"
                                SemanticProperties.Hint="Double tap to hand off turn-by-turn directions to Google Maps"
                                Command="{Binding OpenInGMapsCommand}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <!-- ── No alarm active — tracking only ──────────────────────────── -->
        <VerticalStackLayout VerticalOptions="End"
                             HorizontalOptions="Fill"
                             Padding="28,0,28,40"
                             Spacing="10"
                             IsVisible="{Binding IsNotAlarmActive}">

            <Label Text="{Binding DistanceToDestinationText}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <!-- Current location + destination, filling the previously-empty sheet space. The current
                 location updates live with every accepted GPS fix. -->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="10" RowSpacing="8"
                  Margin="4,4,4,0">
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="#3D2B5E" StrokeShape="Ellipse" Stroke="Transparent"
                        WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                    <Label Text="my_location" FontFamily="MaterialSymbols"
                           FontSize="16" TextColor="#4A90D9"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="Current Location" FontSize="11" TextColor="#8A7AAE" />
                    <Label Text="{Binding CurrentLocationText}"
                           FontSize="14" FontAttributes="Bold" TextColor="White"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>

                <Border Grid.Row="1" Grid.Column="0"
                        BackgroundColor="#3D2B5E" StrokeShape="Ellipse" Stroke="Transparent"
                        WidthRequest="36" HeightRequest="36" VerticalOptions="Center">
                    <Label Text="location_on" FontFamily="MaterialSymbols"
                           FontSize="16" TextColor="#9B6FBF"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="1" VerticalOptions="Center">
                    <Label Text="Destination" FontSize="11" TextColor="#8A7AAE" />
                    <Label Text="{Binding DestinationShortNameText}"
                           FontSize="14" FontAttributes="Bold" TextColor="White"
                           LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
            </Grid>

            <Button Text="Stop Trip"
                    BackgroundColor="#4A3570"
                    TextColor="White"
                    CornerRadius="24"
                    FontSize="16"
                    Padding="0,14"
                    Margin="0,6,0,0"
                    SemanticProperties.Description="Stop current trip"
                    SemanticProperties.Hint="Double tap to stop tracking and return to the home screen"
                    Clicked="OnStopTripClicked" />

        </VerticalStackLayout>

    </Grid>
</ContentPage>
