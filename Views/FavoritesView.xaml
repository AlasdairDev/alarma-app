<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AlarmaApp.Models"
             x:Class="AlarmaApp.Views.FavoritesView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A0F35">

    <Grid HorizontalOptions="Fill" VerticalOptions="Fill" RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto"
              Padding="24,52,20,16"
              BackgroundColor="#1A0F35">
            <Label Grid.Column="0"
                   Text="Favorites"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="+"
                    FontSize="22"
                    BackgroundColor="#4A3570"
                    TextColor="White"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="22"
                    Padding="0"
                    Command="{Binding AddRouteToFavoritesCommand}" />
        </Grid>

        <!-- Content area -->
        <Grid Grid.Row="1">

            <!-- Empty state (compass) -->
            <VerticalStackLayout IsVisible="{Binding HasNoSavedRoutes}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="0">
                <Grid WidthRequest="180"
                      HeightRequest="180"
                      HorizontalOptions="Center">
                    <Ellipse WidthRequest="160"
                             HeightRequest="160"
                             Stroke="#4A3570"
                             StrokeThickness="2"
                             Fill="Transparent"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                    <Label Text="&#129517;"
                           FontSize="72"
                           TextColor="#7B3FA0"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                    <Label Text="&#11088;"
                           FontSize="24"
                           TextColor="#9B6FBF"
                           HorizontalOptions="End"
                           VerticalOptions="Start"
                           Margin="0,10,10,0" />
                </Grid>

                <Label Text="No favorites yet."
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"
                       Margin="0,16,0,8" />
                <Label Text="Add favorites from the Home Screen by tapping the star on a place. They'll show here and for one-tap trips."
                       FontSize="14"
                       TextColor="#8A7AAE"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"
                       Margin="32,0" />
            </VerticalStackLayout>

            <!-- Favorites list -->
            <ScrollView IsVisible="{Binding HasSavedRoutes}">
                <VerticalStackLayout Spacing="0">
                    <CollectionView ItemsSource="{Binding SavedRoutes}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SavedRoute">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Padding="16,14"
                                      BackgroundColor="Transparent">
                                    <Border Grid.Column="0"
                                            BackgroundColor="#4A3570"
                                            StrokeShape="Ellipse"
                                            Stroke="Transparent"
                                            WidthRequest="44"
                                            HeightRequest="44"
                                            VerticalOptions="Start"
                                            Margin="0,2,0,0">
                                        <Label Text="&#128205;"
                                               FontSize="18"
                                               TextColor="#9B6FBF"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <Label Grid.Column="1"
                                           Text="{Binding FullAddress}"
                                           FontSize="13"
                                           TextColor="White"
                                           LineBreakMode="WordWrap"
                                           MaxLines="3"
                                           Margin="14,0,0,0"
                                           VerticalOptions="Center" />

                                    <Label Grid.Column="2"
                                           Text="&#11088;"
                                           FontSize="20"
                                           TextColor="#9B6FBF"
                                           VerticalOptions="Start"
                                           Margin="8,4,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveSavedRouteCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnFavoriteRouteTapped" />
                                    </Grid.GestureRecognizers>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <BoxView HeightRequest="24" Color="Transparent" />
                </VerticalStackLayout>
            </ScrollView>

        </Grid>

    </Grid>
</ContentPage>
